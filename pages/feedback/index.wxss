.feedback-chip {
  padding: 12rpx 18rpx;
  border: 2rpx solid #d8c99d;
  border-radius: 16rpx;
  background: #fff9e9;
  color: #51351f;
  font-size: 24rpx;
  font-weight: 800;
  white-space: nowrap;
  word-break: keep-all;
}

.feedback-chip.active {
  border-color: #55a85a;
  background: #e7f4d8;
  color: #214d28;
  box-shadow: 0 4rpx 0 rgba(85, 168, 90, 0.28);
}

.counter {
  margin-top: 8rpx;
  color: #7c735f;
  font-size: 22rpx;
  text-align: right;
}

.save-btn {
  margin-top: 28rpx;
}

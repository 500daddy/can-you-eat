.camera-card {
  margin-top: 24rpx;
  padding: 20rpx;
  border: 4rpx solid #2f6c37;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #4ba952, #2f6c37);
}

.camera-frame {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 520rpx;
  overflow: hidden;
  border-radius: 22rpx;
  background: #fffdf2;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.camera-icon {
  width: 100rpx;
  height: 100rpx;
}

.camera-text {
  position: absolute;
  bottom: 150rpx;
  color: #51351f;
  font-size: 28rpx;
  font-weight: 900;
}

.corner {
  position: absolute;
  width: 56rpx;
  height: 56rpx;
  border-color: #fffdf2;
  border-style: solid;
}

.lt {
  left: 28rpx;
  top: 28rpx;
  border-width: 6rpx 0 0 6rpx;
}

.rt {
  right: 28rpx;
  top: 28rpx;
  border-width: 6rpx 6rpx 0 0;
}

.lb {
  left: 28rpx;
  bottom: 28rpx;
  border-width: 0 0 6rpx 6rpx;
}

.rb {
  right: 28rpx;
  bottom: 28rpx;
  border-width: 0 6rpx 6rpx 0;
}

.recognize-state {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 16rpx;
  color: #fffdf2;
  font-size: 25rpx;
  font-weight: 800;
}

.tiny-baby {
  width: 44rpx;
  height: 44rpx;
}

.result-helper {
  margin: 8rpx 0 16rpx;
  color: #7c735f;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.45;
}

.result-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
  padding: 18rpx;
  border: 3rpx solid #d8c99d;
  border-radius: 20rpx;
  background: #fffdf2;
  box-shadow: 0 4rpx 0 rgba(81, 53, 31, 0.08);
}

.result-card:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 0 rgba(81, 53, 31, 0.08);
}

.result-icon {
  width: 82rpx;
  height: 82rpx;
}

.result-main {
  flex: 1;
  min-width: 0;
}

.result-label {
  color: #7c735f;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
}

.result-name {
  margin-top: 2rpx;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
}

.confidence-bar {
  height: 16rpx;
  margin-top: 12rpx;
  overflow: hidden;
  border: 2rpx solid #8bb774;
  border-radius: 12rpx;
  background: #fff9e9;
}

.confidence-fill {
  height: 100%;
  background: #55a85a;
}

.confidence-copy {
  margin-top: 8rpx;
  color: #7c735f;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.2;
}

.result-action {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 112rpx;
  min-height: 62rpx;
  padding: 0 14rpx;
  border: 3rpx solid #2f6c37;
  border-radius: 16rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.26), rgba(255, 255, 255, 0) 40%),
    linear-gradient(180deg, #63bd68, #3f8a43);
  color: #fffdf2;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.15;
  text-align: center;
  white-space: nowrap;
  box-shadow: inset 0 3rpx 0 rgba(255, 255, 255, 0.28), 0 5rpx 0 #24602c;
}

.manual-btn {
  margin-top: 28rpx;
}

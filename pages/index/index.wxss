.home-page {
  padding-top: 0;
}

.home-page .village-hero {
  min-height: 456rpx;
  margin: 0 -24rpx 24rpx;
  padding: 0 34rpx 26rpx;
  border: 0;
  border-radius: 0 0 34rpx 34rpx;
  background: #f5dca9;
  box-shadow: 0 8rpx 0 rgba(81, 53, 31, 0.12);
}

.home-page .village-hero::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(255, 245, 214, 0.1), rgba(255, 249, 233, 0.02) 56%, rgba(251, 246, 223, 0.28));
  pointer-events: none;
}

.home-page .hero-bg {
  top: 0;
  bottom: auto;
  height: 100%;
  opacity: 1;
}

.home-page .hero-content {
  min-height: 430rpx;
  padding-top: 132rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.baby-row {
  align-self: flex-start;
  display: flex;
  align-items: center;
  gap: 18rpx;
  max-width: 560rpx;
  padding: 12rpx 20rpx 12rpx 12rpx;
  border: 3rpx solid rgba(81, 53, 31, 0.28);
  border-radius: 28rpx;
  background: rgba(255, 253, 242, 0.84);
  box-shadow: 0 6rpx 0 rgba(81, 53, 31, 0.12);
}

.baby-avatar {
  width: 96rpx;
  height: 96rpx;
  border: 3rpx solid #51351f;
  border-radius: 22rpx;
  background: #fff9e9;
}

.baby-info {
  min-width: 0;
}

.home-page .pixel-title {
  color: #214d28;
  text-shadow: 0 3rpx 0 #fff4c7, 0 0 8rpx rgba(255, 253, 242, 0.8);
}

.baby-row .subtitle {
  color: #6b5735;
  font-weight: 700;
}

.hero-card {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border: 3rpx solid rgba(81, 53, 31, 0.2);
  border-radius: 22rpx;
  background: rgba(255, 253, 242, 0.9);
  backdrop-filter: blur(2px);
}

.button-row .pixel-btn {
  flex: 1;
}

.btn-symbol {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  margin-right: 10rpx;
  border: 3rpx solid #fffdf2;
  border-radius: 10rpx;
  color: #fffdf2;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1;
}

.home-page {
  padding-top: 0;
  background: linear-gradient(180deg, #aee2ee 0, #c7eadb 410rpx, #fbf6df 456rpx, #fbf6df 100%);
}

.home-page .village-hero {
  min-height: 450rpx;
  margin: -6rpx -24rpx 20rpx;
  padding: 0 34rpx 26rpx;
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.home-page .village-hero::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 249, 233, 0) 72%);
  pointer-events: none;
}

.home-page .hero-bg {
  top: -10rpx;
  bottom: auto;
  height: calc(100% + 16rpx);
  opacity: 1;
}

.home-page .hero-content {
  min-height: 302rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.home-nav {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  height: 154rpx;
  padding-bottom: 25rpx;
  color: #fffdf2;
  font-size: 27rpx;
  font-weight: 900;
  text-shadow: 0 3rpx 0 rgba(47, 108, 55, 0.5);
}

.baby-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.baby-avatar {
  width: 96rpx;
  height: 96rpx;
  border: 3rpx solid #51351f;
  border-radius: 22rpx;
  background: #fff9e9;
}

.hero-card {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border: 3rpx solid rgba(81, 53, 31, 0.2);
  border-radius: 22rpx;
  background: rgba(255, 253, 242, 0.9);
  box-shadow: 0 5rpx 0 rgba(81, 53, 31, 0.12);
}

.button-row .pixel-btn {
  flex: 1;
}

.home-page .button-row,
.home-page .section-head,
.home-page food-card,
.home-page .disclaimer {
  position: relative;
  z-index: 1;
}

.home-page .button-row {
  margin-top: 0;
}

.btn-symbol {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  margin-right: 10rpx;
  border: 3rpx solid #fffdf2;
  border-radius: 10rpx;
  color: #fffdf2;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1;
}

.purchase-plan-page {
  padding-bottom: 64rpx;
}

.recommend-row {
  margin: 16rpx 0 24rpx;
}

.plan-guide {
  margin-top: 14rpx;
  padding: 16rpx;
  border: 2rpx dashed #d89a43;
  border-radius: 18rpx;
  background: #fff8dc;
  color: #8a4a16;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.45;
}

.plan-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding: 18rpx;
  border: 3rpx solid #d8c99d;
  border-radius: 22rpx;
  background: #fffdf2;
}

.plan-icon {
  width: 88rpx;
  height: 88rpx;
}

.plan-main {
  flex: 1;
  min-width: 0;
}

.plan-actions {
  display: flex;
  flex: 0 0 112rpx;
  flex-direction: column;
  gap: 12rpx;
}

.plan-name {
  color: #2d261c;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
}

.plan-meta {
  margin-top: 6rpx;
  color: #7c735f;
  font-size: 23rpx;
  line-height: 1.35;
}

.choose-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 58rpx;
  border: 3rpx solid #68aa63;
  border-radius: 16rpx;
  background: #e7f4d8;
  color: #2f6c37;
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.58), 0 4rpx 0 rgba(84, 143, 75, 0.3);
}

.delete-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 52rpx;
  border: 3rpx solid #d77768;
  border-radius: 16rpx;
  background: #fff0e8;
  color: #a43f31;
  font-size: 23rpx;
  font-weight: 900;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.62), 0 4rpx 0 rgba(191, 95, 70, 0.25);
}

.save-btn {
  margin-top: 20rpx;
}

.save-btn.disabled {
  opacity: 0.7;
}

<view class="page with-tab">
  <view class="profile-card" bindtap="goBaby">
    <image class="profile-avatar" src="{{settings.babyAvatarImage || assets.mascot.babyFront}}" mode="aspectFill" />
    <view class="profile-main">
      <view class="profile-name">{{settings.babyName || '新手村村民'}}</view>
      <view class="subtitle">宝宝月龄：{{settings.babyAgeText}}</view>
    </view>
    <view class="profile-side">
      <text class="profile-stage">{{settings.babyStageText || '辅食探索'}}</text>
      <text class="profile-edit">编辑 ›</text>
    </view>
    <view wx:if="{{settings.babyStageDescription}}" class="profile-stage-desc">{{settings.babyStageDescription}}</view>
  </view>

  <view class="stats-grid">
    <view class="stat-card {{item.action === 'score' ? 'info' : 'tappable'}}" wx:for="{{stats}}" wx:key="label" data-action="{{item.action}}" data-tab="{{item.tab}}" bindtap="handleStatTap">
      <view class="stat-value">{{item.value}}</view>
      <view class="stat-label">{{item.label}}</view>
      <view wx:if="{{item.action === 'score'}}" class="stat-info">?</view>
      <view wx:elif="{{item.action}}" class="stat-arrow">›</view>
    </view>
  </view>

  <view class="paper-card">
    <view class="list-cell" bindtap="goBaby">
      <text>宝宝模式设置</text>
      <text class="cell-note">{{settings.babyMode ? '开启中' : '未开启'}} ›</text>
    </view>
    <view class="list-cell" bindtap="goReminder">
      <text>提醒设置</text>
      <text class="cell-note">{{settings.dailySummaryTime}} ›</text>
    </view>
    <view class="list-cell" bindtap="goFamily">
      <text>家庭共享</text>
      <text class="cell-note">共用食材库 ›</text>
    </view>
  </view>

  <view class="paper-card">
    <view class="list-cell" bindtap="goFeedback">
      <text>意见反馈</text>
      <text class="cell-note">帮助我们做得更好 ›</text>
    </view>
    <view class="list-cell" bindtap="goAbout">
      <text>关于小程序</text>
      <text class="cell-note">安心版 0.1 ›</text>
    </view>
  </view>
</view>

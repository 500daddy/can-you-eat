<view class="page with-tab">
  <view class="account-card">
    <view class="account-profile" bindtap="goAccount">
      <image class="account-avatar" src="{{account.profile.avatarUrl || '/assets/sprites/nav/nav_pixel_mine_active.png'}}" mode="aspectFill" />
      <view class="account-main">
        <view wx:if="{{account.loggedIn}}" class="account-name">{{account.profile.nickname || '微信用户'}}</view>
        <view wx:else class="account-name">微信登录</view>
        <view wx:if="{{account.loggedIn}}" class="account-subtitle">微信账号 · 账号设置</view>
        <view wx:else class="account-subtitle">登录后与家人共用食材库</view>
      </view>
      <view class="account-action">{{account.loggedIn ? '设置' : '登录'}} ›</view>
    </view>

    <view wx:if="{{account.loggedIn && account.familyLoadError}}" class="family-summary is-error" bindtap="retryFamily">
      <view>
        <view class="family-title">家庭共享</view>
        <view class="family-meta">加载失败，点击重试</view>
      </view>
      <view class="family-arrow">›</view>
    </view>
    <view wx:elif="{{account.loggedIn}}" class="family-summary" bindtap="goFamily">
      <view>
        <view class="family-title">家庭共享 · {{account.familyName || '我的家庭'}}</view>
        <view class="family-meta">{{account.familyRoleText}} · {{account.familyMemberCount}} 人</view>
      </view>
      <view class="family-arrow">›</view>
    </view>

    <view wx:if="{{account.loggedIn && account.syncStatus === 'pending'}}" class="sync-status" catchtap="retrySync">
      <text>本机食材待同步</text>
      <text class="sync-action">{{syncing ? '同步中…' : '重试 ›'}}</text>
    </view>
  </view>

  <view class="stats-grid">
    <view class="stat-card {{item.action === 'score' ? 'info' : 'tappable'}}" wx:for="{{stats}}" wx:key="label" data-action="{{item.action}}" data-tab="{{item.tab}}" bindtap="handleStatTap">
      <view class="stat-value">{{item.value}}</view>
      <view class="stat-label">{{item.label}}</view>
      <view wx:if="{{item.action === 'score'}}" class="stat-info">?</view>
      <view wx:elif="{{item.action}}" class="stat-arrow">›</view>
    </view>
  </view>

  <view class="paper-card">
    <view class="list-cell" bindtap="goBaby">
      <text>宝宝模式设置</text>
      <text class="cell-note">{{babySettingNote}} ›</text>
    </view>
    <view class="list-cell" bindtap="goReminder">
      <text>提醒设置</text>
      <text class="cell-note">{{reminderTime}} ›</text>
    </view>
  </view>

  <view class="paper-card">
    <view class="list-cell" bindtap="goFeedback">
      <text>意见反馈</text>
      <text class="cell-note">帮助我们做得更好 ›</text>
    </view>
    <view class="list-cell" bindtap="goAbout">
      <text>关于小程序</text>
      <text class="cell-note">安心版 0.1 ›</text>
    </view>
  </view>
</view>

.account-card {
  border: 4rpx solid #8ebf7b;
  border-radius: 24rpx;
  background: #fffdf2;
  overflow: hidden;
}

.account-profile {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 118rpx;
  padding: 22rpx;
}

.account-profile.is-logged-out {
  min-height: 92rpx;
  padding: 18rpx 22rpx;
}

.account-avatar {
  flex: 0 0 auto;
  width: 104rpx;
  height: 104rpx;
  border: 3rpx solid #51351f;
  border-radius: 20rpx;
  background: #fff9e9;
}

.account-main {
  flex: 1;
  min-width: 0;
}

.account-name {
  color: #2d261c;
  font-size: 32rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.account-subtitle {
  margin-top: 8rpx;
  color: #7c735f;
  font-size: 23rpx;
}

.account-action,
.family-arrow {
  color: #2f6c37;
  font-size: 24rpx;
  font-weight: 900;
  white-space: nowrap;
}

.login-family-hint {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 86rpx;
  margin: 0 22rpx;
  padding: 16rpx 0 18rpx;
  border-top: 2rpx solid #e6dcba;
}

.login-family-copy {
  min-width: 0;
}

.login-family-title {
  color: #315d32;
  font-size: 25rpx;
  font-weight: 900;
}

.login-family-meta {
  margin-top: 5rpx;
  color: #7c735f;
  font-size: 21rpx;
  line-height: 1.35;
}

.login-family-status {
  flex: 0 0 auto;
  padding: 8rpx 12rpx;
  border-radius: 10rpx;
  background: #f0edda;
  color: #8a806d;
  font-size: 20rpx;
  font-weight: 800;
  white-space: nowrap;
}

.family-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 82rpx;
  margin: 0 22rpx;
  padding: 16rpx 0;
  border-top: 2rpx solid #e6dcba;
}

.family-title {
  color: #315d32;
  font-size: 26rpx;
  font-weight: 900;
}

.family-meta {
  margin-top: 5rpx;
  color: #7c735f;
  font-size: 23rpx;
}

.family-summary.is-error .family-meta {
  color: #a65d35;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 22rpx;
}

.stat-card {
  position: relative;
  min-height: 120rpx;
  padding: 18rpx 8rpx;
  border: 3rpx solid #d8c99d;
  border-radius: 22rpx;
  background: #fffdf2;
  text-align: center;
}

.stat-card.tappable {
  border-color: #c9da9c;
  box-shadow: 0 5rpx 0 rgba(84, 143, 75, 0.18);
}

.stat-card.info {
  border-style: dashed;
}

.list-cell {
  align-items: center;
  line-height: 1;
}

.list-cell > text {
  display: inline-flex;
  align-items: center;
  min-height: 86rpx;
}

.cell-note {
  display: inline-flex;
  align-items: center;
  justify-content: flex-end;
  line-height: 1.2;
}

.stat-value {
  color: #2d261c;
  font-size: 34rpx;
  font-weight: 900;
}

.stat-label {
  margin-top: 8rpx;
  color: #7c735f;
  font-size: 21rpx;
  line-height: 1.25;
  white-space: nowrap;
  word-break: keep-all;
}

.stat-arrow,
.stat-info {
  position: absolute;
  top: 10rpx;
  right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 26rpx;
  height: 26rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 900;
}

.stat-arrow {
  color: #3f8a43;
}

.stat-info {
  border: 2rpx solid #d8c99d;
  background: #fff9e9;
  color: #7c735f;
}

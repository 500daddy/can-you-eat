.profile-card {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 18rpx;
  padding: 22rpx;
  border: 4rpx solid #8ebf7b;
  border-radius: 28rpx;
  background: #fffdf2;
}

.profile-avatar {
  width: 116rpx;
  height: 116rpx;
  border: 3rpx solid #51351f;
  border-radius: 22rpx;
  background: #fff9e9;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.profile-name {
  color: #2d261c;
  font-size: 34rpx;
  font-weight: 900;
}

.profile-stage {
  display: inline-flex;
  padding: 8rpx 14rpx;
  border: 2rpx solid #e4bf68;
  border-radius: 14rpx;
  background: #fff0b8;
  color: #9a5c12;
  font-size: 22rpx;
  font-weight: 900;
}

.profile-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.profile-edit {
  color: #2f6c37;
  font-size: 22rpx;
  font-weight: 900;
  white-space: nowrap;
}

.profile-stage-desc {
  flex: 0 0 100%;
  padding: 12rpx 16rpx;
  border: 2rpx solid #e4d9aa;
  border-radius: 16rpx;
  background: #fff8df;
  color: #7c6847;
  font-size: 23rpx;
  line-height: 1.45;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 22rpx;
}

.stat-card {
  position: relative;
  min-height: 120rpx;
  padding: 18rpx 8rpx;
  border: 3rpx solid #d8c99d;
  border-radius: 22rpx;
  background: #fffdf2;
  text-align: center;
}

.stat-card.tappable {
  border-color: #c9da9c;
  box-shadow: 0 5rpx 0 rgba(84, 143, 75, 0.18);
}

.stat-card.info {
  border-style: dashed;
}

.list-cell {
  align-items: center;
  line-height: 1;
}

.list-cell > text {
  display: inline-flex;
  align-items: center;
  min-height: 86rpx;
}

.cell-note {
  display: inline-flex;
  align-items: center;
  justify-content: flex-end;
  line-height: 1.2;
}

.stat-value {
  color: #2d261c;
  font-size: 34rpx;
  font-weight: 900;
}

.stat-label {
  margin-top: 8rpx;
  color: #7c735f;
  font-size: 21rpx;
  line-height: 1.25;
  white-space: nowrap;
  word-break: keep-all;
}

.stat-arrow,
.stat-info {
  position: absolute;
  top: 10rpx;
  right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 26rpx;
  height: 26rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 900;
}

.stat-arrow {
  color: #3f8a43;
}

.stat-info {
  border: 2rpx solid #d8c99d;
  background: #fff9e9;
  color: #7c735f;
}

.ai-lab-card {
  margin-top: 22rpx;
  overflow: hidden;
}

.ai-lab-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.ai-lab-card.expanded .ai-lab-head {
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #eadfb9;
}

.ai-lab-heading {
  flex: 1;
  min-width: 0;
}

.ai-lab-head-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex: 0 0 auto;
}

.ai-lab-badge {
  flex: 0 0 auto;
  padding: 6rpx 12rpx;
  border: 2rpx solid #d4bd74;
  border-radius: 999rpx;
  background: #fff8df;
  color: #8b681f;
  font-size: 21rpx;
  font-weight: 900;
}

.ai-lab-toggle {
  color: #2f6c37;
  font-size: 22rpx;
  font-weight: 900;
}

.ai-lab-list {
  margin-top: 14rpx;
}

.ai-lab-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f0e5c3;
}

.ai-lab-item:last-child {
  border-bottom: 0;
}

.ai-lab-icon {
  width: 56rpx;
  height: 56rpx;
  padding: 8rpx;
  border: 3rpx solid #d8c99d;
  border-radius: 16rpx;
  background: #fff9e9;
  box-sizing: border-box;
}

.ai-lab-main {
  flex: 1;
  min-width: 0;
}

.ai-lab-title {
  color: #2d261c;
  font-size: 26rpx;
  font-weight: 900;
}

.ai-lab-desc {
  margin-top: 6rpx;
  color: #7c735f;
  font-size: 21rpx;
  line-height: 1.35;
}

.ai-lab-status {
  flex: 0 0 auto;
  color: #3f8a43;
  font-size: 22rpx;
  font-weight: 900;
}

.ai-lab-item.pending .ai-lab-status {
  color: #8a806d;
}

<view class="page detail-page">
  <view class="detail-header">
    <image wx:if="{{record.showFoodIcon}}" class="detail-food-icon" src="{{record.displayFoodIcon}}" mode="aspectFit" />
    <view class="detail-main">
      <view class="detail-name">{{record.name}}</view>
      <status-tag status="{{record.status}}" />
      <view class="subtitle">{{statusInfo.adviceTitle}}</view>
    </view>
    <image class="edit-icon" src="{{assets.actions.edit}}" mode="aspectFit" bindtap="edit" />
  </view>

  <view class="paper-card yellow">
    <view class="section-title">宝宝建议</view>
    <view class="advice-text">{{statusInfo.advice}}</view>
  </view>

  <view class="paper-card">
    <view class="info-row">
      <text>购买日期</text>
      <text class="info-value">{{record.purchaseDate}}</text>
    </view>
    <view class="info-row">
      <text>保存方式</text>
      <text class="info-value">{{record.storageText}}</text>
    </view>
    <view class="info-row">
      <text>已保存天数</text>
      <text class="info-value">{{record.savedDays}}</text>
    </view>
    <view class="info-row">
      <text>宝宝建议截止日</text>
      <text class="info-value">{{record.babyExpireDate}}</text>
    </view>
    <view class="info-row">
      <text>成人参考截止日</text>
      <text class="info-value">{{record.adultExpireDate}}</text>
    </view>
  </view>

  <view class="paper-card green">
    <view class="section-title">保存建议</view>
    <view class="tip" wx:for="{{base.tips}}" wx:key="*this">{{item}}</view>
  </view>

  <view class="paper-card process-advice-card">
    <view class="section-title">处理建议</view>
    <view class="process-title">{{processAdvice.title}}</view>
    <view wx:if="{{processAdvice.dishes.length}}" class="dish-row">
      <text wx:for="{{processAdvice.dishes}}" wx:key="*this" class="dish-chip">{{item}}</text>
    </view>
    <view wx:for="{{processAdvice.steps}}" wx:key="*this" class="tip process-tip">{{item}}</view>
  </view>

  <view class="paper-card">
    <view class="section-title">变质迹象</view>
    <view class="chip-row signs">
      <text class="chip" wx:for="{{base.spoilageSigns}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <view class="paper-card adult-note">
    超过宝宝建议期后，给宝宝前请重新检查外观、气味和触感。
  </view>

  <view wx:if="{{auditLogs.length}}" class="paper-card audit-card">
    <view class="section-title">最近编辑记录</view>
    <view class="audit-row" wx:for="{{auditLogs}}" wx:key="id">
      <view class="audit-dot">{{item.actionText}}</view>
      <view class="audit-main">
        <view class="audit-summary">{{item.summaryText}}</view>
        <view class="subtitle">{{item.actorText}} · {{item.timeText}}</view>
      </view>
    </view>
  </view>

  <view class="detail-actions fixed-action-dock">
    <view class="pixel-btn" bindtap="finish">已吃掉</view>
    <view class="pixel-btn secondary" bindtap="keepAdult">留给大人吃</view>
    <view class="pixel-btn ghost" bindtap="edit">编辑记录</view>
    <view class="pixel-btn danger" bindtap="remove">删除</view>
  </view>

  <view class="disclaimer">
    保存建议仅供参考，实际状态更重要。
  </view>
</view>

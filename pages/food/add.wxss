.selected-food {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 24rpx;
  padding: 18rpx;
  border: 3rpx solid #8ebf7b;
  border-radius: 24rpx;
  background: #fffdf2;
}

.selected-icon {
  width: 104rpx;
  height: 104rpx;
}

.selected-main {
  flex: 1;
}

.selected-name {
  color: #2d261c;
  font-size: 34rpx;
  font-weight: 900;
}

.custom-tip {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 3rpx dashed #d89a43;
  border-radius: 20rpx;
  background: #fff8dc;
}

.custom-tip-title {
  margin-bottom: 6rpx;
  color: #8a4a16;
  font-size: 26rpx;
  font-weight: 900;
}

.field-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 26rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f3f8df;
}

.no-margin {
  margin-bottom: 0;
}

.remind-box {
  padding: 18rpx;
  border: 2rpx dashed #8bb774;
  border-radius: 18rpx;
  background: #fbfff0;
  color: #2f6c37;
  font-size: 24rpx;
  font-weight: 800;
}

.save-btn {
  margin-top: 28rpx;
}

.save-btn.disabled {
  opacity: 0.72;
  box-shadow: inset 0 3rpx 0 rgba(255, 255, 255, 0.35), 0 3rpx 0 rgba(36, 96, 44, 0.28);
}

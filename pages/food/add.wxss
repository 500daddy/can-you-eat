.page {
  padding-bottom: calc(176rpx + env(safe-area-inset-bottom));
}

.selected-food {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding: 18rpx;
  border: 3rpx solid #8ebf7b;
  border-radius: 24rpx;
  background: #fffdf2;
}

.selected-main {
  flex: 1;
  min-width: 0;
}

.selected-food-icon {
  flex: 0 0 auto;
  width: 74rpx;
  height: 74rpx;
  margin-right: 16rpx;
}

.selected-name {
  color: #2d261c;
  font-size: 34rpx;
  font-weight: 900;
}

.readonly-food-name {
  display: flex;
  align-items: center;
  width: 100%;
  height: 76rpx;
  min-height: 76rpx;
  padding: 0 20rpx;
  border: 2rpx solid #cfe0ad;
  border-radius: 18rpx;
  background: #f3f8df;
  color: #2d261c;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}

.readonly-food-icon {
  flex: 0 0 auto;
  width: 48rpx;
  height: 48rpx;
  margin-right: 12rpx;
}

.readonly-food-name text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.date-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.date-trigger-arrow {
  color: #2f6c37;
  font-size: 23rpx;
  font-weight: 900;
}

.field-helper {
  margin-top: 10rpx;
  color: #7c735f;
  font-size: 22rpx;
  line-height: 1.45;
}

.storage-helper {
  margin: -4rpx 0 14rpx;
  padding: 12rpx 16rpx;
  border: 2rpx dashed #a9c98d;
  border-radius: 16rpx;
  background: #f7fbdf;
  color: #2f6c37;
  font-weight: 800;
}

.segment {
  position: relative;
  flex-direction: column;
  gap: 6rpx;
  min-height: 78rpx;
  padding: 13rpx 8rpx 12rpx;
  border-width: 3rpx;
  border-color: #d8c99d;
  background: linear-gradient(180deg, #fffef7, #fff8e4);
  box-shadow: inset 0 3rpx 0 rgba(255, 255, 255, 0.9), 0 4rpx 0 rgba(81, 53, 31, 0.14);
  line-height: 1;
}

.segment.active {
  border-color: #55a85a;
  background: linear-gradient(180deg, #f3fbdf, #dff1cf);
  box-shadow: inset 0 3rpx 0 rgba(255, 255, 255, 0.8), 0 4rpx 0 rgba(47, 108, 55, 0.22);
}

.recommend-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 50rpx;
  height: 24rpx;
  padding: 0 8rpx;
  border: 2rpx solid #d28a2d;
  border-radius: 999rpx;
  background: #fff0b8;
  color: #9a5515;
  font-size: 17rpx;
  font-weight: 900;
  line-height: 1;
}

.custom-tip {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 3rpx dashed #d89a43;
  border-radius: 20rpx;
  background: #fff8dc;
}

.custom-tip-title {
  margin-bottom: 6rpx;
  color: #8a4a16;
  font-size: 26rpx;
  font-weight: 900;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 26rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f3f8df;
}

.no-margin {
  margin-bottom: 0;
}

.remind-box {
  padding: 18rpx;
  border: 2rpx dashed #8bb774;
  border-radius: 18rpx;
  background: #fbfff0;
  color: #2f6c37;
  font-size: 24rpx;
  font-weight: 800;
}

.save-dock {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 3rpx solid rgba(216, 201, 157, 0.8);
  background: rgba(255, 249, 233, 0.96);
  box-shadow: 0 -8rpx 24rpx rgba(81, 53, 31, 0.12);
}

.save-dock-text {
  margin-bottom: 10rpx;
  color: #7c735f;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
  white-space: nowrap;
  word-break: keep-all;
}

.save-btn {
  height: 80rpx;
  min-height: 80rpx;
  border-width: 4rpx;
  border-color: #24602c;
  border-radius: 20rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0) 35%),
    linear-gradient(180deg, #63bd68, #3f8a43);
  font-size: 30rpx;
  letter-spacing: 1rpx;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.3), 0 7rpx 0 #24602c;
}

.save-btn.disabled {
  opacity: 0.72;
  box-shadow: inset 0 3rpx 0 rgba(255, 255, 255, 0.35), 0 3rpx 0 rgba(36, 96, 44, 0.28);
}

.date-sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: flex;
  align-items: flex-end;
  background: rgba(45, 38, 28, 0.45);
}

.date-sheet {
  width: 100%;
  padding: 18rpx 22rpx calc(22rpx + env(safe-area-inset-bottom));
  border-top: 4rpx solid #8ebf7b;
  border-radius: 28rpx 28rpx 0 0;
  background: #fff9e9;
  box-shadow: 0 -10rpx 28rpx rgba(81, 53, 31, 0.16);
}

.date-sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 72rpx;
}

.date-sheet-title {
  color: #2d261c;
  font-size: 28rpx;
  font-weight: 900;
}

.date-sheet-action {
  min-width: 96rpx;
  color: #2f8d3d;
  font-size: 27rpx;
  font-weight: 900;
  text-align: center;
}

.date-sheet-action.muted {
  color: #7c735f;
}

.date-picker-view {
  width: 100%;
  height: 360rpx;
  margin-top: 8rpx;
  border: 3rpx solid #d8c99d;
  border-radius: 20rpx;
  background: #fffdf2;
  overflow: hidden;
}

.date-option {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  color: #2d261c;
  font-size: 29rpx;
  font-weight: 900;
}

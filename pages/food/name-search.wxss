.name-search-page {
  min-height: 100vh;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 24rpx;
  min-height: 82rpx;
  padding: 10rpx 12rpx 10rpx 18rpx;
  border: 3rpx solid #d8c99d;
  border-radius: 22rpx;
  background: #fffdf2;
}

.search-icon {
  width: 38rpx;
  height: 38rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 27rpx;
}

.search-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 126rpx;
  width: 126rpx;
  height: 60rpx;
  border: 2rpx solid #2f6c37;
  border-radius: 16rpx;
  background: #55a85a;
  color: #fff;
  font-size: 25rpx;
  font-weight: 900;
  white-space: nowrap;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.24), 0 4rpx 0 #2f6c37;
}

.quick-section {
  margin: 8rpx 0 24rpx;
}

.quick-section-title {
  margin-bottom: 14rpx;
  color: #1f6b35;
  font-size: 27rpx;
  font-weight: 900;
}

.quick-food-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.quick-food-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 146rpx;
  padding: 14rpx 8rpx;
  border: 3rpx solid #79b872;
  border-radius: 20rpx;
  background: #fffdf2;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.55), 0 4rpx 0 rgba(92, 145, 78, 0.18);
}

.quick-food-card:active {
  transform: translateY(2rpx);
  box-shadow: inset 0 3rpx 0 rgba(255, 255, 255, 0.5), 0 2rpx 0 rgba(92, 145, 78, 0.18);
}

.quick-food-name {
  max-width: 100%;
  color: #235b2b;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.recent-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  max-width: 210rpx;
  min-height: 58rpx;
  padding: 8rpx 16rpx;
  border: 3rpx solid #d8c99d;
  border-radius: 18rpx;
  background: #fff8df;
  color: #5d4127;
  font-size: 24rpx;
  font-weight: 900;
  white-space: nowrap;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.58), 0 3rpx 0 rgba(180, 143, 77, 0.18);
}

.recent-chip text {
  overflow: hidden;
  text-overflow: ellipsis;
}

.result-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding: 18rpx;
  border: 3rpx solid #d8c99d;
  border-radius: 22rpx;
  background: #fffdf2;
}

.food-icon-slot {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 76rpx;
  width: 76rpx;
  min-height: 76rpx;
}

.food-icon-img {
  width: 68rpx;
  height: 68rpx;
}

.recommendation-tip {
  margin: -4rpx 0 16rpx;
  padding: 14rpx 18rpx;
  border: 3rpx solid #8ebf7b;
  border-radius: 18rpx;
  background: #fbfff0;
  color: #5f6f42;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.45;
}

.recommendation-tip text {
  margin-right: 8rpx;
  color: #2f6c37;
  font-weight: 900;
}

.profile-prompt {
  display: inline-flex;
  align-items: center;
  margin: -4rpx 0 16rpx;
  padding: 8rpx 16rpx;
  border: 2rpx solid #8ebf7b;
  border-radius: 999rpx;
  background: #e7f4d8;
  color: #2f6c37;
  font-size: 22rpx;
  font-weight: 900;
  white-space: nowrap;
}

.result-main {
  flex: 1;
  min-width: 0;
}

.result-name {
  color: #2d261c;
  font-size: 30rpx;
  font-weight: 900;
  white-space: nowrap;
}

.result-reason {
  display: inline-flex;
  margin-top: 6rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #e7f4d8;
  color: #2f6c37;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.25;
}

.result-meta {
  margin-top: 6rpx;
  color: #7c735f;
  font-size: 23rpx;
  line-height: 1.35;
}

.choose-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 102rpx;
  width: 102rpx;
  height: 58rpx;
  border: 3rpx solid #68aa63;
  border-radius: 16rpx;
  background: #e7f4d8;
  color: #2f6c37;
  font-size: 25rpx;
  font-weight: 900;
  white-space: nowrap;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.58), 0 4rpx 0 rgba(84, 143, 75, 0.3);
}

.empty-card {
  text-align: center;
}

.not-found {
  display: block;
  width: 190rpx;
  height: 150rpx;
  margin: 0 auto 12rpx;
}

.custom-btn {
  margin-top: 18rpx;
}

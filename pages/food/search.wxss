.search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 24rpx;
  min-height: 82rpx;
  padding: 10rpx 12rpx 10rpx 18rpx;
  border: 3rpx solid #d8c99d;
  border-radius: 22rpx;
  background: #fffdf2;
}

.search-icon {
  width: 38rpx;
  height: 38rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 27rpx;
}

.search-btn {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 126rpx;
  width: 126rpx;
  height: 60rpx;
  margin: 0;
  padding: 0;
  border: 2rpx solid #2f6c37;
  border-radius: 16rpx;
  background: #55a85a;
  color: #fff;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.1;
  white-space: nowrap;
  word-break: keep-all;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.24), 0 4rpx 0 #2f6c37;
}

.category-card {
  margin-bottom: 22rpx;
  padding: 16rpx;
  border: 3rpx solid #d8c99d;
  border-radius: 22rpx;
  background: #fffdf2;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.category-tile {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 144rpx;
  padding: 12rpx 8rpx;
  border: 3rpx solid #8ebf7b;
  border-radius: 22rpx;
  background: #fbfff0;
  color: #2f6c37;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.5);
}

.category-tile.active {
  border-color: #2f6c37;
  background: #e7f4d8;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.5), 0 4rpx 0 rgba(47, 108, 55, 0.25);
}

.category-icon {
  width: 70rpx;
  height: 70rpx;
  margin-bottom: 4rpx;
}

.category-name {
  color: #2f6c37;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.2;
  text-align: center;
  white-space: nowrap;
  word-break: keep-all;
}

.category-count {
  margin-top: 2rpx;
  color: #7c735f;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
  white-space: nowrap;
  word-break: keep-all;
}

.category-tile.active .category-count {
  color: #4d7a45;
}

.subcategory-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx dashed #d8c99d;
}

.subcategory-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  min-height: 58rpx;
  padding: 0 20rpx;
  border: 3rpx solid #8ebf7b;
  border-radius: 18rpx;
  background: #fbfff0;
  color: #2f6c37;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.15;
  text-align: center;
  white-space: nowrap;
  word-break: keep-all;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.5);
}

.subcategory-chip text {
  margin-left: 8rpx;
  color: #7c735f;
  font-size: 21rpx;
}

.subcategory-chip.active {
  border-color: #2f6c37;
  background: #55a85a;
  color: #fff;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.22), 0 4rpx 0 #2f6c37;
}

.subcategory-chip.active text {
  color: #eff9df;
}

.result-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding: 18rpx;
  border: 3rpx solid #d8c99d;
  border-radius: 22rpx;
  background: #fffdf2;
}

.result-icon {
  width: 92rpx;
  height: 92rpx;
}

.result-main {
  flex: 1;
  min-width: 0;
}

.result-name {
  color: #2d261c;
  font-size: 30rpx;
  font-weight: 900;
  white-space: nowrap;
  word-break: keep-all;
}

.result-meta {
  margin-top: 6rpx;
  color: #7c735f;
  font-size: 23rpx;
  line-height: 1.35;
}

.choose-btn {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 102rpx;
  width: 102rpx;
  height: 58rpx;
  margin: 0;
  padding: 0;
  border: 3rpx solid #68aa63;
  border-radius: 16rpx;
  background: #e7f4d8;
  color: #2f6c37;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.1;
  white-space: nowrap;
  word-break: keep-all;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.58), 0 4rpx 0 rgba(84, 143, 75, 0.3);
}

.not-found {
  display: block;
  width: 190rpx;
  height: 150rpx;
  margin: 0 auto 12rpx;
}

.empty-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
}

.text-action {
  color: #2f6c37;
  font-size: 24rpx;
  font-weight: 900;
  text-decoration: underline;
}

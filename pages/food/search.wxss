.search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 24rpx;
  min-height: 82rpx;
  padding: 10rpx 12rpx 10rpx 18rpx;
  border: 3rpx solid #d8c99d;
  border-radius: 22rpx;
  background: #fffdf2;
}

.search-icon {
  width: 38rpx;
  height: 38rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 27rpx;
}

.search-btn {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 126rpx;
  width: 126rpx;
  height: 60rpx;
  margin: 0;
  padding: 0;
  border: 2rpx solid #2f6c37;
  border-radius: 16rpx;
  background: #55a85a;
  color: #fff;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.1;
  white-space: nowrap;
  word-break: keep-all;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.24), 0 4rpx 0 #2f6c37;
}

.search-fallback {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin: -6rpx 0 24rpx;
  padding: 14rpx 18rpx;
  border: 3rpx dashed #8ebf7b;
  border-radius: 18rpx;
  background: #fbfff0;
}

.search-fallback-icon {
  flex: 0 0 auto;
  width: 38rpx;
  height: 38rpx;
}

.search-fallback-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.search-fallback-title {
  color: #235b2b;
  font-size: 24rpx;
  font-weight: 900;
  white-space: nowrap;
}

.search-fallback-text {
  color: #6f654e;
  font-size: 22rpx;
  font-weight: 800;
  white-space: nowrap;
}

.search-fallback-arrow {
  color: #2f6c37;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
}

.show-all-action {
  max-width: 210rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-card {
  margin-bottom: 22rpx;
  padding: 12rpx;
  border: 3rpx solid #d8c99d;
  border-radius: 22rpx;
  background: #fffdf2;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.category-tile {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 106rpx;
  padding: 8rpx 6rpx;
  border: 3rpx solid #8ebf7b;
  border-radius: 18rpx;
  background: #fbfff0;
  color: #2f6c37;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.5);
}

.category-tile.active {
  border-color: #2f6c37;
  background: #e7f4d8;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.5), 0 4rpx 0 rgba(47, 108, 55, 0.25);
}

.category-icon {
  width: 54rpx;
  height: 54rpx;
  margin-bottom: 2rpx;
}

.category-name {
  color: #2f6c37;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.2;
  text-align: center;
  white-space: nowrap;
  word-break: keep-all;
}

.subcategory-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10rpx 12rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 2rpx dashed #d8c99d;
}

.subcategory-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 108rpx;
  min-height: 54rpx;
  padding: 0 18rpx;
  border: 2rpx solid #8ebf7b;
  border-radius: 16rpx;
  background: #fbfff0;
  color: #2f6c37;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.15;
  text-align: center;
  white-space: nowrap;
  word-break: keep-all;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.5);
}

.subcategory-chip.active {
  border-color: #2f6c37;
  background: #55a85a;
  color: #fff;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.22), 0 4rpx 0 #2f6c37;
}

.result-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding: 18rpx;
  border: 3rpx solid #d8c99d;
  border-radius: 22rpx;
  background: #fffdf2;
}

.food-icon-slot {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 76rpx;
  width: 76rpx;
  min-height: 76rpx;
}

.food-icon-img {
  width: 68rpx;
  height: 68rpx;
}

.recommendation-tip {
  margin: -4rpx 0 16rpx;
  padding: 14rpx 18rpx;
  border: 3rpx solid #8ebf7b;
  border-radius: 18rpx;
  background: #fbfff0;
  color: #5f6f42;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.45;
}

.recommendation-tip text {
  margin-right: 8rpx;
  color: #2f6c37;
  font-weight: 900;
}

.profile-prompt {
  display: inline-flex;
  align-items: center;
  margin: -4rpx 0 16rpx;
  padding: 8rpx 16rpx;
  border: 2rpx solid #8ebf7b;
  border-radius: 999rpx;
  background: #e7f4d8;
  color: #2f6c37;
  font-size: 22rpx;
  font-weight: 900;
  white-space: nowrap;
}

.result-main {
  flex: 1;
  min-width: 0;
}

.result-name {
  color: #2d261c;
  font-size: 30rpx;
  font-weight: 900;
  white-space: nowrap;
  word-break: keep-all;
}

.result-reason {
  display: inline-flex;
  margin-top: 6rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #e7f4d8;
  color: #2f6c37;
  font-size: 20rpx;
  font-weight: 900;
}

.result-meta {
  margin-top: 6rpx;
  color: #7c735f;
  font-size: 23rpx;
  line-height: 1.35;
}

.choose-btn {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 102rpx;
  width: 102rpx;
  height: 58rpx;
  margin: 0;
  padding: 0;
  border: 3rpx solid #68aa63;
  border-radius: 16rpx;
  background: #e7f4d8;
  color: #2f6c37;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.1;
  white-space: nowrap;
  word-break: keep-all;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.58), 0 4rpx 0 rgba(84, 143, 75, 0.3);
}

.not-found {
  display: block;
  width: 190rpx;
  height: 150rpx;
  margin: 0 auto 12rpx;
}

.empty-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
}

.text-action {
  color: #2f6c37;
  font-size: 24rpx;
  font-weight: 900;
  text-decoration: underline;
}

.back-top {
  position: fixed;
  right: 28rpx;
  bottom: calc(150rpx + env(safe-area-inset-bottom));
  z-index: 30;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 108rpx;
  border: 3rpx solid #2f6c37;
  border-radius: 24rpx;
  background: #e7f4d8;
  color: #2f6c37;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.12;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.58), 0 6rpx 0 rgba(47, 108, 55, 0.28), 0 8rpx 18rpx rgba(69, 53, 30, 0.16);
}

.back-top-arrow {
  margin-bottom: 2rpx;
  font-size: 34rpx;
  line-height: 1;
}

<view class="page with-tab">
  <view class="page-title">添加食材</view>
  <view class="subtitle">搜索食材名称，也可以先从常见食材里选一个</view>

  <view class="search-box">
    <image class="search-icon" src="{{assets.actions.search}}" mode="aspectFit" />
    <input class="search-input" placeholder="搜索食材名称，如：西兰花" value="{{keyword}}" bindinput="onInput" confirm-type="search" bindconfirm="search" />
    <button class="search-btn" bindtap="search">搜索</button>
  </view>

  <view class="section-head">
    <view class="section-title">常见食材</view>
    <view class="section-more">更多分类 ›</view>
  </view>
  <view class="food-grid">
    <view class="food-tile" wx:for="{{hotFoods}}" wx:key="id" data-id="{{item.id}}" bindtap="chooseFood">
      <image class="tile-icon" src="{{item.icon}}" mode="aspectFit" />
      <text>{{item.name}}</text>
    </view>
  </view>

  <view class="section-head">
    <view class="section-title">搜索结果</view>
    <view class="section-more">{{results.length}} 个</view>
  </view>
  <block wx:if="{{results.length}}">
    <view class="result-card" wx:for="{{results}}" wx:key="id" data-id="{{item.id}}" bindtap="chooseFood">
      <image class="result-icon" src="{{item.icon}}" mode="aspectFit" />
      <view class="result-main">
        <view class="result-name">{{item.name}}</view>
        <view class="result-meta">{{item.category}}｜别名：{{item.aliases}}</view>
        <view class="result-meta">推荐保存：{{item.defaultStorage === 'room' ? '常温' : item.defaultStorage === 'freezer' ? '冷冻' : '冷藏'}}｜宝宝建议期：{{item.babyDays}}</view>
      </view>
      <button class="choose-btn" size="mini">选择</button>
    </view>
  </block>

  <view wx:else class="paper-card">
    <image class="not-found" src="{{assets.mascot.emptyNotFound}}" mode="aspectFit" />
    <view class="section-title">没找到这个食材</view>
    <view class="subtitle">可以按分类添加，或先创建一个自定义食材。</view>
    <button class="pixel-btn ghost" bindtap="goAdd">创建新食材</button>
  </view>
</view>

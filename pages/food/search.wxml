<view class="page with-tab">
  <view class="page-title">按分类找食材</view>
  <view class="subtitle">先选大类，再看细分类；知道名称时可以直接去搜索。</view>

  <view id="category-section" class="section-head">
    <view class="section-title">食材分类</view>
  </view>
  <view class="category-card">
    <view class="category-grid">
      <view class="category-tile {{!activeCategory && resultTitle === '推荐食材' ? 'active' : ''}}" bindtap="selectRecommended">
        <image class="category-icon" src="{{assets.food.babyPuree}}" mode="aspectFit" />
        <view class="category-name">推荐</view>
      </view>
      <view class="category-tile {{activeCategory === category.name ? 'active' : ''}}" wx:for="{{categoryGroups}}" wx:for-item="category" wx:key="name" data-name="{{category.name}}" bindtap="selectCategory">
        <image class="category-icon" src="{{category.icon}}" mode="aspectFit" />
        <view class="category-name">{{category.name}}</view>
      </view>
    </view>
    <view wx:if="{{subCategories.length}}" class="subcategory-grid">
      <view class="subcategory-chip {{activeSubCategory === item.name ? 'active' : ''}}" wx:for="{{subCategories}}" wx:key="name" data-name="{{item.name}}" bindtap="selectSubCategory">
        {{item.name}}
      </view>
    </view>
  </view>
  <view class="search-fallback" bindtap="goNameSearch">
    <image class="search-fallback-icon" src="{{assets.actions.search}}" mode="aspectFit" />
    <view class="search-fallback-main">
      <view class="search-fallback-title">找不到合适分类？</view>
      <view class="search-fallback-text">去搜索食材名称</view>
    </view>
    <view class="search-fallback-arrow">›</view>
  </view>

  <view class="section-head">
    <view class="section-title">{{resultTitle}}</view>
    <view wx:if="{{!activeCategory && resultTitle === '推荐食材'}}" class="section-more show-all-action" bindtap="clearCategory">查看全部食材</view>
    <view wx:else class="section-more">{{results.length}} 个</view>
  </view>
  <view wx:if="{{recommendationHint}}" class="recommendation-tip">
    <text>{{recommendationSummary.babyAgeText}} · {{recommendationSummary.stageLabel}}</text>
    {{recommendationHint}}
  </view>
  <view wx:if="{{needsBabyProfilePrompt && resultTitle === '推荐食材'}}" class="profile-prompt" bindtap="goBabySettings">
    完善宝宝信息，推荐更准
  </view>
  <block wx:if="{{results.length}}">
    <view class="result-card" wx:for="{{results}}" wx:key="id" data-id="{{item.id}}" bindtap="chooseFood">
      <view wx:if="{{item.reserveFoodIconSlot}}" class="food-icon-slot">
        <image wx:if="{{item.showFoodIcon}}" class="food-icon-img" src="{{item.displayFoodIcon}}" mode="aspectFit" />
      </view>
      <view class="result-main">
        <view class="result-name">{{item.name}}</view>
        <view wx:if="{{item.recommendationStage}}" class="result-reason">适配 {{item.recommendationStage}} 宝宝</view>
        <view class="result-meta">{{item.category}}｜别名：{{item.aliases}}</view>
        <view class="result-meta">推荐保存：{{item.defaultStorage === 'room' ? '常温' : item.defaultStorage === 'freezer' ? '冷冻' : '冷藏'}}｜宝宝建议期：{{item.babyDays}}</view>
      </view>
      <view class="choose-btn">选择</view>
    </view>
  </block>

  <view wx:else class="paper-card">
    <image class="not-found" src="{{assets.mascot.emptyNotFound}}" mode="aspectFit" />
    <view class="section-title">没找到这个食材</view>
    <view class="subtitle">可以创建自定义食材，保存后会进入首页提醒；也可以告诉我们补充食材库。</view>
    <view class="empty-actions">
      <view class="pixel-btn ghost" bindtap="goAdd">创建并加入提醒</view>
      <view class="text-action" bindtap="goFeedback">反馈缺少食材</view>
    </view>
  </view>

  <view wx:if="{{showBackTop}}" class="back-top" bindtap="scrollToTop">
    <view class="back-top-arrow">↑</view>
    <view>顶部</view>
  </view>
</view>

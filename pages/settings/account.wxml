<view class="page account-page">
  <view class="page-title">家长账号</view>
  <view class="subtitle">登录后可与家人共用食材库，并在换设备后继续查看记录。</view>

  <view class="profile-card">
    <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="avatar-preview" src="{{avatarUrl || assets.account.defaultAvatar}}" mode="aspectFill" />
      <view class="avatar-badge">更换</view>
    </button>
    <view class="profile-main">
      <view class="label">家长昵称</view>
      <input class="input nickname-input" type="nickname" value="{{nickname}}" bindinput="onNicknameInput" bindchange="onNicknameChange" bindblur="onNicknameBlur" placeholder="请输入你的昵称" />
      <view class="nickname-help">可选择微信昵称，也可以自己填写</view>
    </view>
  </view>

  <view wx:if="{{loggedIn}}" class="paper-card family-card" bindtap="goFamily">
    <view>
      <view class="section-title">家庭共享</view>
      <view class="subtitle">{{familyName || '我的家庭'}} · {{familyRoleText}} · {{familyMemberCount}} 人</view>
    </view>
    <view class="cell-arrow">管理 ›</view>
  </view>

  <view wx:if="{{loggedIn && syncStatus === 'pending'}}" class="sync-card">
    <view>
      <view class="sync-title">本机食材还未同步完成</view>
      <view class="subtitle">本机数据仍然保留，可以重新同步。</view>
    </view>
    <view class="pixel-btn ghost compact-action" bindtap="retrySync">{{syncing ? '同步中…' : '重新同步'}}</view>
  </view>

  <view wx:if="{{loggedIn}}" class="logout-section">
    <view class="logout-button" bindtap="logout">退出登录</view>
  </view>

  <view class="sticky-save-bar">
    <view class="pixel-btn save-action {{saving ? 'is-disabled' : ''}}" bindtap="saveAccount">
      {{saving ? (loggedIn ? '正在保存…' : '正在登录…') : (loggedIn ? '保存账号信息' : '登录并同步')}}
    </view>
  </view>
</view>

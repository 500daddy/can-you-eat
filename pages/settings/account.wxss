.account-page {
  padding-bottom: calc(178rpx + env(safe-area-inset-bottom));
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  border: 3rpx solid #8ebf7b;
  border-radius: 24rpx;
  background: #fffdf2;
  box-shadow: 0 6rpx 0 rgba(81, 53, 31, 0.08);
}

.avatar-button {
  position: relative;
  flex: 0 0 auto;
  width: 126rpx;
  height: 126rpx;
  border: 3rpx solid #51351f;
  border-radius: 20rpx;
  background: #fff9e9;
  overflow: hidden;
}

.avatar-preview {
  width: 100%;
  height: 100%;
}

.avatar-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 7rpx 0;
  background: rgba(33, 77, 40, 0.86);
  color: #fff;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1;
  text-align: center;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.nickname-input {
  height: 72rpx;
  min-height: 72rpx;
  line-height: 72rpx;
}

.family-card,
.sync-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.cell-arrow {
  flex: 0 0 auto;
  color: #2f6c37;
  font-size: 24rpx;
  font-weight: 900;
}

.sync-card {
  margin-top: 22rpx;
  padding: 22rpx;
  border: 3rpx solid #e4bf68;
  border-radius: 20rpx;
  background: #fff8d8;
}

.sync-title {
  color: #51351f;
  font-size: 26rpx;
  font-weight: 900;
}

.compact-action {
  flex: 0 0 auto;
  min-height: 60rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  font-size: 23rpx;
}

.logout-section {
  margin-top: 38rpx;
  text-align: center;
}

.logout-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 68rpx;
  padding: 0 30rpx;
  border: 2rpx solid #d9b8aa;
  border-radius: 16rpx;
  background: #fffaf0;
  color: #a44a3f;
  font-size: 24rpx;
  font-weight: 800;
}

.sticky-save-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 3rpx solid rgba(216, 201, 157, 0.85);
  background: rgba(255, 249, 233, 0.97);
  box-shadow: 0 -8rpx 20rpx rgba(81, 53, 31, 0.12);
}

.save-action {
  width: 100%;
  min-height: 82rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.28), 0 7rpx 0 #2f6c37;
}

.save-action.is-disabled {
  opacity: 0.72;
}

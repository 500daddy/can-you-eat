<view class="page">
  <view class="page-title">提醒设置</view>
  <view class="subtitle">设置食材临期提醒和每日摘要时间，减少遗漏。</view>

  <view class="paper-card">
    <view class="setting-row">
      <view>
        <view class="setting-title">临期前提醒</view>
        <view class="subtitle">在宝宝建议期结束前提醒</view>
      </view>
      <switch checked="{{reminderEnabled}}" color="#55a85a" bindchange="onReminderSwitch" />
    </view>
    <view class="setting-row">
      <view>
        <view class="setting-title">当天提醒</view>
        <view class="subtitle">当天仍未处理时提醒</view>
      </view>
      <switch checked="{{todayEnabled}}" color="#55a85a" bindchange="onTodaySwitch" />
    </view>
    <view class="setting-row">
      <view>
        <view class="setting-title">每日摘要</view>
        <view class="subtitle">每天 {{dailyTimeText}} 汇总食材情况</view>
      </view>
      <switch checked="{{dailyEnabled}}" color="#55a85a" bindchange="onDailySwitch" />
    </view>
    <view class="time-setting" wx:if="{{dailyEnabled}}">
      <view class="time-options">
        <view
          wx:for="{{dailyTimeOptions}}"
          wx:key="value"
          class="time-chip {{item.selected ? 'active' : ''}}"
          data-value="{{item.value}}"
          bindtap="selectDailyTimeOption"
        >
          {{item.label}}
        </view>
      </view>
      <picker mode="time" value="{{dailyTime}}" bindchange="onDailyTimeChange">
        <view class="time-picker-row">
          <view>
            <view class="setting-title compact">自定义时间</view>
            <view class="subtitle">当前 {{dailyTime}}</view>
          </view>
          <view class="time-picker-value">修改</view>
        </view>
      </picker>
    </view>
  </view>

  <view class="paper-card yellow">
    <view class="section-title">微信提醒</view>
    <view class="subtitle">开启后，可在微信里收到食材临期提醒。</view>
    <view class="pixel-btn ghost" bindtap="requestSubscribe">开启微信提醒</view>
  </view>

  <view class="pixel-btn save-btn" bindtap="save">保存设置</view>
</view>

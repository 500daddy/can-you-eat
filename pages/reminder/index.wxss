.tabs {
  display: flex;
  gap: 0;
  margin-top: 24rpx;
  margin-bottom: 20rpx;
  padding: 8rpx;
  border: 3rpx solid #d8c99d;
  border-radius: 22rpx;
  background: #fff9e9;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.64), 0 5rpx 0 rgba(81, 53, 31, 0.08);
}

.tab {
  position: relative;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 10rpx 6rpx;
  border: 3rpx solid transparent;
  border-radius: 16rpx;
  background: transparent;
  color: #7c735f;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.18;
  text-align: center;
  white-space: nowrap;
  word-break: keep-all;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tab.active {
  border-color: #68aa63;
  background: linear-gradient(180deg, #eff9df, #dff0ce);
  color: #214d28;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.5), 0 4rpx 0 rgba(84, 143, 75, 0.26);
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  border-bottom: 2rpx solid rgba(216, 201, 157, 0.5);
  color: #51351f;
  font-size: 27rpx;
  font-weight: 800;
}

.daily-time-row {
  gap: 18rpx;
}

.setting-subtitle {
  margin-top: 6rpx;
  color: #8a806d;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.25;
}

.setting-subtitle.strong {
  margin-top: 0;
  color: #51351f;
  font-size: 24rpx;
  font-weight: 900;
}

.setting-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.inline-edit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 76rpx;
  height: 54rpx;
  padding: 0 16rpx;
  border: 3rpx solid #d8c99d;
  border-radius: 14rpx;
  background: #fff9e9;
  color: #2f7d3a;
  font-size: 23rpx;
  font-weight: 900;
  box-shadow: inset 0 3rpx 0 rgba(255, 255, 255, 0.64), 0 3rpx 0 rgba(81, 53, 31, 0.08);
}

.inline-time-editor {
  padding: 18rpx 0 20rpx;
  border-bottom: 2rpx solid rgba(216, 201, 157, 0.5);
}

.time-options {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.time-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  padding: 0 12rpx;
  border: 3rpx solid #d8c99d;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #fffef7, #fff8e4);
  color: #6e5a3c;
  font-size: 23rpx;
  font-weight: 900;
  box-shadow: inset 0 3rpx 0 rgba(255, 255, 255, 0.72), 0 4rpx 0 rgba(81, 53, 31, 0.08);
}

.time-chip.active {
  border-color: #55a85a;
  background: linear-gradient(180deg, #eff9df, #dff0ce);
  color: #214d28;
  box-shadow: inset 0 3rpx 0 rgba(255, 255, 255, 0.6), 0 4rpx 0 rgba(84, 143, 75, 0.22);
}

.time-picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 72rpx;
  margin-top: 16rpx;
  padding: 0 18rpx;
  border: 3rpx dashed #d8c99d;
  border-radius: 16rpx;
  background: #fff9e9;
}

.time-picker-value {
  min-width: 80rpx;
  color: #2f7d3a;
  font-size: 23rpx;
  font-weight: 900;
  text-align: right;
}

.reminder-action-stack {
  display: grid;
  gap: 18rpx;
  margin-top: 22rpx;
}

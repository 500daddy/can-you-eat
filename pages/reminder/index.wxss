.tabs {
  display: flex;
  gap: 0;
  margin-top: 24rpx;
  margin-bottom: 20rpx;
  padding: 8rpx;
  border: 3rpx solid #d8c99d;
  border-radius: 22rpx;
  background: #fff9e9;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.64), 0 5rpx 0 rgba(81, 53, 31, 0.08);
}

.tab {
  position: relative;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 10rpx 6rpx;
  border: 3rpx solid transparent;
  border-radius: 16rpx;
  background: transparent;
  color: #7c735f;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.18;
  text-align: center;
  white-space: nowrap;
  word-break: keep-all;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tab.active {
  border-color: #68aa63;
  background: linear-gradient(180deg, #eff9df, #dff0ce);
  color: #214d28;
  box-shadow: inset 0 4rpx 0 rgba(255, 255, 255, 0.5), 0 4rpx 0 rgba(84, 143, 75, 0.26);
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  border-bottom: 2rpx solid rgba(216, 201, 157, 0.5);
  color: #51351f;
  font-size: 27rpx;
  font-weight: 800;
}

.reminder-action-stack {
  display: grid;
  gap: 18rpx;
  margin-top: 22rpx;
}

<view class="page">
  <view class="member-page-head">
    <view class="page-title">成员管理</view>
    <button class="role-help-btn" bindtap="showRolePermissions">身份权限说明</button>
  </view>
  <view class="subtitle">创建者可以调整家人的身份；成员和管理员仍可一起记录食材。</view>

  <view wx:if="{{!canManageMembers}}" class="paper-card yellow">
    <view class="section-title">仅可查看</view>
    <view class="subtitle">成员身份由家庭创建者维护。</view>
  </view>

  <view class="paper-card member-manage-card">
    <view class="member-manage-row" wx:for="{{members}}" wx:key="openId">
      <view class="member-info">
        <view class="member-name">{{item.nickname || '家庭成员'}}</view>
        <view class="subtitle">{{item.roleText}}</view>
      </view>
      <view class="member-actions" wx:if="{{!item.isOwner}}">
        <view class="role-actions">
          <button class="role-btn {{item.role === 'member' ? 'active' : ''}}" data-openid="{{item.openId}}" data-role="member" bindtap="updateRole" disabled="{{!!removingOpenId || !!updatingOpenId || !!pendingRemovalOpenId}}">成员</button>
          <button class="role-btn {{item.role === 'admin' ? 'active' : ''}}" data-openid="{{item.openId}}" data-role="admin" bindtap="updateRole" disabled="{{!!removingOpenId || !!updatingOpenId || !!pendingRemovalOpenId}}">管理员</button>
        </view>
        <view class="remove-actions" wx:if="{{canManageMembers && !item.isOwner}}">
          <button class="remove-member-btn" data-openid="{{item.openId}}" bindtap="removeMember" disabled="{{!!removingOpenId || !!updatingOpenId || (!!pendingRemovalOpenId && pendingRemovalOpenId !== item.openId)}}">{{removingOpenId === item.openId ? '处理中' : (pendingRemovalOpenId === item.openId ? '确认状态' : '移出家庭')}}</button>
        </view>
      </view>
      <view wx:else class="role-owner">创建者</view>
    </view>
  </view>
</view>

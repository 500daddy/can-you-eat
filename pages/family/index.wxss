.family-card {
  margin-top: 22rpx;
}

.family-sync-note {
  margin-top: 16rpx;
  color: #8a7447;
}

.family-main,
.card-head,
.member-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.family-name {
  color: var(--green-900);
  font-size: 36rpx;
  font-weight: 900;
}

.member-count {
  min-width: 86rpx;
  padding: 12rpx 16rpx;
  border: 2rpx solid #8ebf7b;
  border-radius: 18rpx;
  background: #fffdf2;
  color: var(--green-800);
  font-size: 28rpx;
  font-weight: 900;
  text-align: center;
}

.invite-card .pixel-btn {
  margin-top: 18rpx;
}

.invite-confirm-card {
  margin-top: 24rpx;
  padding: 30rpx;
}

.invite-eyebrow {
  margin-bottom: 8rpx;
  color: #3f8a43;
  font-size: 22rpx;
  font-weight: 900;
}

.invite-note {
  margin-top: 20rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(142, 191, 123, 0.65);
  border-radius: 16rpx;
  background: #fffdf2;
  color: #6f6757;
  font-size: 23rpx;
  line-height: 1.6;
}

.confirm-join-btn {
  width: 100%;
  margin-top: 24rpx;
}

.share-ready-btn {
  background: #3f9f49;
}

.join-card {
  padding-bottom: 24rpx;
}

.other-join-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.join-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
}

.join-input {
  flex: 1;
}

.join-btn {
  width: 150rpx;
  flex: 0 0 auto;
}

.copy-invite-btn {
  margin: 18rpx auto 0;
  padding: 8rpx 18rpx;
  border: 0;
  background: transparent;
  color: #6f6757;
  font-size: 22rpx;
  text-decoration: underline;
}

.copy-invite-btn::after {
  border: 0;
}

.invite-code {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 3rpx dashed #d8b65c;
  border-radius: 18rpx;
  background: #fffdf2;
  color: var(--brown-900);
  font-size: 28rpx;
  font-weight: 900;
  word-break: break-all;
}

.member-row {
  min-height: 108rpx;
  border-bottom: 2rpx solid rgba(216, 201, 157, 0.5);
}

.member-row:last-child {
  border-bottom: 0;
}

.member-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border: 2rpx solid #8ebf7b;
  border-radius: 18rpx;
  background: #e7f4d8;
  color: var(--green-900);
  font-size: 26rpx;
  font-weight: 900;
}

.member-info {
  flex: 1;
  min-width: 0;
}

.member-name {
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 900;
}

.role-badge {
  padding: 8rpx 14rpx;
  border: 2rpx solid #d8c99d;
  border-radius: 14rpx;
  background: #fff9e9;
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 900;
}

.role-badge.owner {
  border-color: #e4bf68;
  background: #fff0b8;
  color: #9a5c12;
}

.role-badge.admin {
  border-color: #8ebf7b;
  background: #e7f4d8;
  color: var(--green-800);
}

.family-exit-card {
  margin: 42rpx 0 20rpx;
  text-align: center;
}

.family-exit-btn {
  width: 280rpx;
  border: 2rpx solid #cf9993;
  border-radius: 16rpx;
  background: transparent;
  color: #a65d57;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 76rpx;
}

.family-exit-btn::after {
  border: 0;
}

.family-exit-btn[disabled] {
  border-color: #d8b9b5;
  background: transparent;
  color: #b98a85;
  opacity: 0.72;
}

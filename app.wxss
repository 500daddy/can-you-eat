page {
  --cream: #fbf6df;
  --cream-2: #fff9e9;
  --paper: #fffdf2;
  --paper-deep: #fff2ca;
  --green-900: #214d28;
  --green-800: #2f6c37;
  --green-700: #3f8a43;
  --green-600: #55a85a;
  --green-100: #e7f4d8;
  --brown-900: #51351f;
  --wood: #b87835;
  --gold: #f4b33e;
  --orange: #ee9b30;
  --red: #e76b64;
  --red-deep: #c94c43;
  --line: #d8c99d;
  --ink: #2d261c;
  --muted: #7c735f;
  min-height: 100%;
  background: var(--cream);
  color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
input,
textarea,
button {
  box-sizing: border-box;
}

button {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  line-height: 1.2;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background:
    linear-gradient(180deg, rgba(231, 244, 216, 0.62), rgba(251, 246, 223, 0) 260rpx),
    var(--cream);
}

.page.with-tab {
  padding-bottom: calc(188rpx + env(safe-area-inset-bottom));
}

.village-hero {
  position: relative;
  overflow: hidden;
  min-height: 188rpx;
  padding: 28rpx;
  border: 4rpx solid #8bb774;
  border-radius: 28rpx;
  background: #e7f4d8;
  box-shadow: 0 6rpx 0 rgba(81, 53, 31, 0.16);
}

.village-hero .hero-bg {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 138rpx;
  opacity: 0.92;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.pixel-title {
  color: var(--green-900);
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.18;
  text-shadow: 0 3rpx 0 #fff4c7;
}

.page-title {
  color: var(--ink);
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.25;
}

.subtitle {
  margin-top: 10rpx;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.55;
}

.paper-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border: 3rpx solid var(--line);
  border-radius: 24rpx;
  background: var(--paper);
  box-shadow: 0 6rpx 0 rgba(81, 53, 31, 0.08);
}

.paper-card.green {
  border-color: #8ebf7b;
  background: linear-gradient(180deg, #fffef2, #eff9e2);
}

.paper-card.yellow {
  border-color: #e4bf68;
  background: linear-gradient(180deg, #fff8d8, #fffdf2);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 28rpx 4rpx 14rpx;
}

.section-title {
  color: var(--green-900);
  font-size: 30rpx;
  font-weight: 900;
  white-space: nowrap;
  word-break: keep-all;
}

.section-more {
  color: var(--green-700);
  font-size: 24rpx;
  font-weight: 700;
  white-space: nowrap;
  word-break: keep-all;
}

.button-row {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
}

.pixel-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  min-height: 76rpx;
  padding: 0 28rpx;
  border: 3rpx solid #2f6c37;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #62bd66, #3f8a43);
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
  word-break: keep-all;
  box-shadow: 0 6rpx 0 #276130;
}

.pixel-btn.secondary {
  border-color: #b87835;
  background: linear-gradient(180deg, #fff0b8, #f7c858);
  color: var(--brown-900);
  box-shadow: 0 6rpx 0 #b87835;
}

.pixel-btn.ghost {
  border-color: #8bb774;
  background: #fffdf2;
  color: var(--green-800);
  box-shadow: 0 5rpx 0 rgba(84, 143, 75, 0.35);
}

.pixel-btn.danger {
  border-color: #b84b43;
  background: linear-gradient(180deg, #f58579, #df5f55);
  color: #fff;
  box-shadow: 0 6rpx 0 #b84b43;
}

.btn-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 10rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 9rpx 16rpx;
  border: 2rpx solid #cdbb88;
  border-radius: 16rpx;
  background: #fff9e9;
  color: var(--brown-900);
  font-size: 23rpx;
  font-weight: 700;
  white-space: nowrap;
  word-break: keep-all;
}

.form-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border: 3rpx solid var(--line);
  border-radius: 24rpx;
  background: var(--paper);
}

.field {
  margin-bottom: 26rpx;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--brown-900);
  font-size: 25rpx;
  font-weight: 900;
  white-space: nowrap;
  word-break: keep-all;
}

.required {
  color: var(--red);
}

.input,
.picker-box {
  width: 100%;
  height: 76rpx;
  min-height: 76rpx;
  padding: 0 20rpx;
  border: 2rpx solid #ddcea1;
  border-radius: 18rpx;
  background: #fffdf7;
  color: var(--ink);
  font-size: 28rpx;
  line-height: 76rpx;
}

.textarea {
  width: 100%;
  min-height: 140rpx;
  padding: 18rpx 20rpx;
  border: 2rpx solid #ddcea1;
  border-radius: 18rpx;
  background: #fffdf7;
  color: var(--ink);
  font-size: 28rpx;
  line-height: 1.5;
}

.picker-box {
  display: flex;
  align-items: center;
}

.segmented {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.segment {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 20rpx 0;
  border: 2rpx solid #ddcea1;
  border-radius: 18rpx;
  background: #fffdf7;
  color: var(--muted);
  text-align: center;
  font-size: 26rpx;
  font-weight: 800;
  white-space: nowrap;
  word-break: keep-all;
}

.segment.active {
  border-color: #68aa63;
  background: #e7f4d8;
  color: var(--green-900);
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 72rpx;
  border-bottom: 2rpx solid rgba(216, 201, 157, 0.6);
  color: var(--muted);
  font-size: 25rpx;
}

.info-row:last-child {
  border-bottom: 0;
}

.info-value {
  color: var(--ink);
  font-weight: 800;
  white-space: nowrap;
  word-break: keep-all;
}

.disclaimer {
  margin: 28rpx 8rpx 0;
  color: #8a806d;
  font-size: 22rpx;
  line-height: 1.65;
}

.list-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 86rpx;
  border-bottom: 2rpx solid rgba(216, 201, 157, 0.5);
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 800;
}

.list-cell:last-child {
  border-bottom: 0;
}

.cell-note {
  color: var(--muted);
  font-size: 24rpx;
  font-weight: 500;
  white-space: nowrap;
  word-break: keep-all;
}
